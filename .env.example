# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.

# --- Database ---
# Production MUST use PostgreSQL. SQLite is only supported for local dev/tests.
# Example Postgres URL: postgresql://alumni_api:password@localhost:5432/alumni_dashboard
DATABASE_URL=postgresql://alumni_api:password@localhost:5432/alumni_dashboard

# --- Credentials CSV ---
# Backend-only login credentials file. Keep this OUTSIDE any publicly
# served/static directory. Never exposed through any API endpoint.
USERS_CSV_PATH=data/users.csv

# --- Security / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed origins (your Lovable-hosted frontend URL(s)).
ALLOWED_ORIGINS=https://your-app.lovable.app

# --- Multi-organization ---
# Used as a fallback when a request omits ?organization=
DEFAULT_ORGANIZATION_SLUG=fsu-cci

# --- App ---
ENVIRONMENT=development
ENABLE_API_DOCS=true

# --- Rate limiting (login brute-force protection) ---
LOGIN_RATE_LIMIT=5/minute

# --- Optional geocoding (disabled by default; app works fully without it) ---
GEOCODING_ENABLED=false
GEOCODING_PROVIDER_API_KEY=
